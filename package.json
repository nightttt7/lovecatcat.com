{
  "name": "lovecatcat-blog",
  "private": true,
  "type": "module",
  "engines": {
    "node": ">=20.18.1"
  },
  "scripts": {
    "build:assets": "node scripts/build-post-editor-preview.mjs",
    "dev": "npm run build:assets && tsx watch src/server.ts",
    "deploy:preview": "wrangler deploy --env preview",
    "deploy:preview:inactive": "wrangler deploy --env preview --config wrangler.preview-inactive.toml",
    "deploy:production": "wrangler deploy --env=\"\"",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage"
  },
  "dependencies": {
    "@hono/node-server": "^1.19.13",
    "@noble/hashes": "^2.0.1",
    "better-sqlite3": "^12.8.0",
    "hono": "^4.12.18",
    "rehype-sanitize": "^6.0.0",
    "rehype-stringify": "^10.0.1",
    "remark-breaks": "^4.0.0",
    "remark-gfm": "^4.0.1",
    "remark-parse": "^11.0.0",
    "remark-rehype": "^11.1.2",
    "unified": "^11.0.5"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20240208.0",
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "^22.10.2",
    "@vitest/coverage-v8": "^4.1.4",
    "esbuild": "^0.28.0",
    "tsx": "^4.19.2",
    "typescript": "^5.6.3",
    "vitest": "^4.1.4",
    "wrangler": "^4.78.0"
  }
}
